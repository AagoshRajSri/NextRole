    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
