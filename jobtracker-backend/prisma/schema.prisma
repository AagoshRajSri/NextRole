datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

model TrackedSearch {
  id               String        @id @default(uuid())
  userId           String
  url              String
  platform         String
  createdAt        DateTime      @default(now())
  lastScrapedAt    DateTime?
  lastScrapeStatus String?       // "ok" | "error" | "empty"
  lastScrapeError  String?
  newJobCount      Int           @default(0)
  snapshots        JobSnapshot[]

  @@index([userId])
  @@unique([userId, url])
}

model JobSnapshot {
  id              String           @id @default(uuid())
  trackedSearchId String
  trackedSearch   TrackedSearch    @relation(fields: [trackedSearchId], references: [id], onDelete: Cascade)
  atsJobId        String
  title           String
  location        String
  url             String
  companyName     String?
  matchReason     String?
  firstSeenAt     DateTime         @default(now())
  isNew           Boolean          @default(true)
  seenAt          DateTime?
  jobEmbedding    Unsupported("vector(1024)")?
  semanticScore   Float?
  tailoredResumes TailoredResume[]

  @@unique([trackedSearchId, atsJobId])
}

model UserProfile {
  id               String   @id @default(uuid())
  userId           String   @unique
  name             String?
  phone            String?
  email            String?
  linkedinUrl      String?
  targetRoles      String[] @default([])
  locations        String[] @default([])
  watchlistCompanies String[] @default([])
  experienceLevel  String?
  alertMode        String   @default("instant")
  emailAlerts      Boolean  @default(false)
  isOnboarded      Boolean  @default(false)
  monitorActive    Boolean  @default(false)
  sessionCookies   Json?
  // Legacy resume fields — kept for premium AI tailoring later
  experience       String   @default("") @db.Text
  skills           String   @default("") @db.Text
  education        String   @default("") @db.Text
  projects         String   @default("") @db.Text
  profileEmbedding Unsupported("vector(1024)")?
  isPremium        Boolean  @default(false)
  monthlyRunsUsed  Int      @default(0)
  updatedAt        DateTime @updatedAt
}

model TailoredResume {
  id            String      @id @default(uuid())
  jobSnapshotId String
  jobSnapshot   JobSnapshot @relation(fields: [jobSnapshotId], references: [id], onDelete: Cascade)
  resumeText    String      @db.Text
  pdfUrl        String?
  createdAt     DateTime    @default(now())
}

model UserSubscription {
  id               String   @id @default(uuid())
  userId           String   @unique
  stripeCustomerId String   @unique
  isActive         Boolean  @default(false)
  updatedAt        DateTime @updatedAt
}
